<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LumiereMediaPlayer.Pages.StreamingYouTubePage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:streaming="using:LumiereMediaPlayer.Services.Streaming"
    mc:Ignorable="d"
    Loaded="OnPageLoaded"
    Unloaded="OnPageUnloaded">

    <Grid x:Name="PageContent" Margin="{StaticResource PageContentMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="14">
                <FontIcon Glyph="&#xE714;" FontSize="32" Foreground="#FFFF0000"/>
                <TextBlock Text="YouTube" Style="{StaticResource PageTitleTextStyle}"/>
            </StackPanel>
            <TextBlock Text="Search for YouTube videos and play them in a seamless hybrid container."
                       Style="{StaticResource PageSubtitleTextStyle}"
                       Opacity="0.7"/>
        </StackPanel>

        <!-- Search Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <AutoSuggestBox
                x:Name="SearchBox"
                PlaceholderText="Search YouTube..."
                QueryIcon="Find"
                QuerySubmitted="OnSearchQuerySubmitted"
                MinWidth="400"
                HorizontalAlignment="Left"/>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="2">
            <!-- Loading indicator -->
            <ProgressRing x:Name="LoadingRing" IsActive="False"
                          Width="48" Height="48"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Status message for errors or empty state -->
            <TextBlock x:Name="StatusText"
                       Text="Search for a video to get started."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="0.5" FontSize="14"/>

            <!-- Search Results List -->
            <ListView x:Name="ResultsList"
                      Visibility="Collapsed"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="OnResultItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="streaming:YouTubeSearchResult">
                        <Grid Padding="8,12" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail -->
                            <Border Grid.Column="0" CornerRadius="6"
                                    Width="160" Height="90">
                                <Border.Background>
                                    <ImageBrush Stretch="UniformToFill"
                                                ImageSource="{x:Bind ThumbnailImage}"/>
                                </Border.Background>
                                <!-- Duration overlay -->
                                <Border Background="#CC000000" CornerRadius="4"
                                        Padding="6,2" HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom" Margin="4">
                                    <TextBlock Text="{x:Bind Duration}" FontSize="11"
                                               Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </Border>

                            <!-- Video Info -->
                            <StackPanel Grid.Column="1" Spacing="6"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Title}"
                                           FontSize="14" FontWeight="SemiBold"
                                           MaxLines="2" TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Author}"
                                           FontSize="12" Opacity="0.8"/>
                                
                                <!-- Rich Stats row -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Opacity="0.6" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewCount}" FontSize="11"/>
                                    <TextBlock Text="·" FontSize="11"/>
                                    <TextBlock Text="{x:Bind LikeCount}" FontSize="11" Visibility="{x:Bind LikesVisibility}"/>
                                    <TextBlock Text="·" FontSize="11" Visibility="{x:Bind LikesVisibility}"/>
                                    <TextBlock Text="{x:Bind CommentCount}" FontSize="11" Visibility="{x:Bind CommentsVisibility}"/>
                                    <TextBlock Text="·" FontSize="11" Visibility="{x:Bind CommentsVisibility}"/>
                                    <TextBlock Text="{x:Bind PublishedAtStr}" FontSize="11"/>
                                </StackPanel>

                                <!-- Badges row -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="#44888888" CornerRadius="4" Padding="6,2" Visibility="{x:Bind HDVisibility}">
                                        <TextBlock Text="HD" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <Border Background="#44888888" CornerRadius="4" Padding="6,2" Visibility="{x:Bind CCVisibility}">
                                        <TextBlock Text="CC" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Play button -->
                            <Button Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="Play Video"
                                    Click="OnPlayButtonClick"
                                    Tag="{x:Bind VideoId}">
                                <FontIcon Glyph="&#xE768;" FontSize="16"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Hybrid WebView2 YouTube Player Overlay -->
            <Grid x:Name="PlayerOverlay" Visibility="Collapsed"
                  Background="Black">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Container where WebView2 will be dynamically hosted -->
                <Grid x:Name="WebViewContainer" Grid.Row="0" Background="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <!-- Native Playback Controls Bar -->
                <Grid x:Name="NativeControlsPanel" Grid.Row="1" Padding="20,16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                    <Grid.Background>
                        <AcrylicBrush TintColor="{ThemeResource SolidBackgroundFillColorBase}" TintOpacity="0.75" FallbackColor="{ThemeResource SolidBackgroundFillColorBase}"/>
                    </Grid.Background>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1: Seek Slider & Times -->
                    <Grid Grid.Row="0" Margin="0,0,0,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ElapsedTimeText" Grid.Column="0" Text="0:00" VerticalAlignment="Center" FontSize="12" Opacity="0.8"/>
                        <Slider x:Name="SeekSlider" Grid.Column="1" Minimum="0" Maximum="100" StepFrequency="1" Margin="0,-6" VerticalAlignment="Center"
                                ManipulationMode="All" ValueChanged="OnSeekSliderValueChanged" PointerCaptureLost="OnSeekSliderPointerCaptureLost" PointerPressed="OnSeekSliderPointerPressed"/>
                        <TextBlock x:Name="TotalTimeText" Grid.Column="2" Text="0:00" VerticalAlignment="Center" FontSize="12" Opacity="0.8"/>
                    </Grid>

                    <!-- Row 2: Playback Info & Action Controls -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left side: Title details -->
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Name="NowPlayingTitle" FontSize="14"
                                       FontWeight="SemiBold" MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="NowPlayingAuthor" FontSize="12"
                                       Opacity="0.6" MaxLines="1"/>
                        </StackPanel>

                        <!-- Center: Transport Controls (Play, Pause) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                            <Button x:Name="PlayPauseButton" Width="40" Height="40" CornerRadius="20"
                                    Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="Play/Pause"
                                    Click="OnPlayPauseClick">
                                <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE769;" FontSize="16"/>
                            </Button>
                        </StackPanel>

                        <!-- Right side: Close & Fullscreen controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <ToggleButton x:Name="ToggleDetailsButton" Click="OnToggleDetailsClick" Style="{ThemeResource DefaultToggleButtonStyle}" ToolTipService.ToolTip="Toggle Video Details">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE90A;" FontSize="14"/>
                                    <TextBlock Text="Details"/>
                                </StackPanel>
                            </ToggleButton>
                            <Button Click="OnStopClick" Width="40" Height="40" CornerRadius="20" ToolTipService.ToolTip="Stop and Close" Style="{ThemeResource DefaultButtonStyle}">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#FFE81123"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFF14C4C"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFA80A17"/>
                                    <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                </Button.Resources>
                                <FontIcon Glyph="&#xE73B;" FontSize="14" Foreground="White"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Row 3: Collapsible Details Grid -->
                    <Grid x:Name="DetailsPane" Grid.Row="2" Margin="0,12,0,0" Padding="0,12,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Stats & Badges Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                <TextBlock x:Name="DetailViewsText" FontSize="12" Opacity="0.8"/>
                                <TextBlock x:Name="DetailLikesText" FontSize="12" Opacity="0.8"/>
                                <TextBlock x:Name="DetailCommentsText" FontSize="12" Opacity="0.8"/>
                                <TextBlock x:Name="DetailDateText" FontSize="12" Opacity="0.8"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Border x:Name="DetailHDBadge" Background="#CC888888" CornerRadius="4" Padding="6,2" Visibility="Collapsed">
                                    <TextBlock Text="HD" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <Border x:Name="DetailCCBadge" Background="#CC888888" CornerRadius="4" Padding="6,2" Visibility="Collapsed">
                                    <TextBlock Text="CC" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Scrollable description & tags -->
                        <ScrollViewer Grid.Row="1" MaxHeight="160" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="8">
                                <!-- Tags -->
                                <TextBlock x:Name="DetailTagsText" FontSize="12" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" TextWrapping="Wrap"/>
                                <!-- Description -->
                                <TextBlock x:Name="DetailDescriptionText" FontSize="13" TextWrapping="Wrap" Opacity="0.85" IsTextSelectionEnabled="True"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
