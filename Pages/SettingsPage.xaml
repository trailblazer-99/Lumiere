                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE8CB;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Sort library by"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Default sorting order for the media library view."/>
                        </StackPanel>
                        <ComboBox Grid.Column="2" MinWidth="160"                                                                               VerticalAlignment="Center" SelectedIndex="{x:Bind ViewModel.SelectedLibrarySortOrderIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Title"/>
                            <ComboBoxItem Content="Artist"/>
                            <ComboBoxItem Content="Date Added"/>
                            <ComboBoxItem Content="Duration"/>
                            <ComboBoxItem Content="Album"/>
                        </ComboBox>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE7B3;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Show hidden files"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Include hidden files in the media library scan."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                        OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.ShowHiddenFiles, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE896;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Auto-import new files"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Automatically import new media files added to library folders."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                           OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.AutoImportNewFiles, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Top">
                            <FontIcon FontSize="16" Glyph="&#xE946;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                            <TextBlock FontSize="14" Text="Supported formats"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="Audio:"/>
                                <Run Text=" .mp3, .wav, .wma, .m4a, .flac, .ogg"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="Video:"/>
                                <Run Text=" .mp4, .mkv, .avi, .mov, .wmv, .webm"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Privacy &amp; History"/>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE81C;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Remember recently played"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Keep a history of recently played media items."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                               OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.RememberRecentlyPlayed, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE8D3;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Remember playback position per track"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Store and resume the last playback position for each individual track."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                                         OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.RememberPlaybackPositionPerTrack, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE74D;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Clear data"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Clear playback history, search history, or recently opened files."/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="Playback history"                                                          VerticalAlignment="Center"/>
                            <Button Content="Search history"                                                        VerticalAlignment="Center"/>
                            <Button Content="Recent files"                                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Accessibility"/>

                
                <TextBlock Text="Vision" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE7F4;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="High contrast mode"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Increase contrast between UI elements for better visibility."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                         OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.HighContrastMode, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE8D2;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Large text mode"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Increase text size throughout the application."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                      OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.LargeTextMode, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE790;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Color blind mode"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Adjust colors for color vision deficiency."/>
                        </StackPanel>
                        <ComboBox Grid.Column="2" MinWidth="160"                                                                             VerticalAlignment="Center" SelectedIndex="{x:Bind ViewModel.SelectedColorBlindModeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Off"/>
                            <ComboBoxItem Content="Protanopia (Red-Green)"/>
                            <ComboBoxItem Content="Deuteranopia (Green-Red)"/>
                            <ComboBoxItem Content="Tritanopia (Blue-Yellow)"/>
                        </ComboBox>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE7F5;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Screen reader optimization"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Optimize UI for screen reader compatibility."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                                 OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.ScreenReaderOptimization, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE7B3;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Focus indicator thickness"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Adjust the thickness of focus indicators around controls."/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Slider Width="120" Minimum="1" Maximum="5" StepFrequency="1"                                                                 Foreground="{ThemeResource AccentFillColorDefaultBrush}" VerticalAlignment="Center" Value="{x:Bind ViewModel.FocusIndicatorThickness, Mode=TwoWay}"/>
                            <TextBlock                                                                    Width="36" TextAlignment="Right" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                
                <TextBlock Text="Hearing" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,12,0,0"/>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xED1E;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Captions always on"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Automatically enable captions for all media."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                         OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.CaptionsAlwaysOn, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE706;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Visual notifications for sound"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Flash visual indicators when audio cues play."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                                    OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.VisualNotificationsForSound, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <TextBlock Text="Motor" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,12,0,0"/>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE765;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Keyboard navigation highlight"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Show visible focus indicators during keyboard navigation."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                                    OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.KeyboardNavigationHighlight, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE8B0;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Larger click targets"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Increase the size of buttons and interactive elements."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                           OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.LargerClickTargets, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE7AD;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Reduce motion"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Minimize animations and transitions throughout the app."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                     OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.ReduceMotion, Mode=TwoWay}"/>
                    </Grid>
                </Border>

                
                <TextBlock Text="Cognitive" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,12,0,0"/>

                
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE7F6;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Auto-read controls"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Announce UI control labels when focused."/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2"                                                         OnContent="" OffContent="" VerticalAlignment="Center" IsOn="{x:Bind ViewModel.AutoReadControls, Mode=TwoWay}"/>
                    </Grid>
                </Border>
            </StackPanel>

            
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Keyboard Shortcuts"/>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Top">
                                <FontIcon FontSize="16" Glyph="&#xE765;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" FontSize="14" Text="Available keyboard shortcuts" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="52,0,0,0" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Space"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" Text="Play / Pause"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Ctrl + Right"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12" Text="Skip forward"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Ctrl + Left"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="12" Text="Skip backward"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Ctrl + I"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" FontSize="12" Text="Properties"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Ctrl + Shift + E"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" FontSize="12" Text="Equaliser"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Ctrl + K"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" FontSize="12" Text="Cast to device"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="F11"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" FontSize="12" Text="Fullscreen"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Up / Down"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" FontSize="12" Text="Volume Up / Down"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Reset &amp; About"/>

                
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,4">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource SmallCornerRadius}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                            <FontIcon FontSize="16" Glyph="&#xE7E6;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontSize="14" Text="Reset settings"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}" Text="Clear caches or reset all settings to factory defaults."/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="Reset history &amp; cache"                                                          VerticalAlignment="Center"/>
                            <Button Content="Factory reset"                                                  Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="18" BorderThickness="2" VerticalAlignment="Center">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFF7E40" Offset="0.0"/>
                                    <GradientStop Color="#FFFF2D55" Offset="0.5"/>
                                    <GradientStop Color="#FF8E52E8" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Grid Background="#FF2A2A2D" CornerRadius="17">
                                <FontIcon FontSize="12" Glyph="&#xE768;" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,0,0"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Fluent Media Player"/>
                            <TextBlock Style="{StaticResource SubtleCaptionTextStyle}"
                                       Text="Version 1.0  •  Built with WinUI 3 &amp; .NET 8"/>
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                <HyperlinkButton Content="Send feedback" Padding="0" FontSize="12"/>
                                <HyperlinkButton Content="Rate this app" Padding="0" FontSize="12"/>
                                <HyperlinkButton Content="GitHub repository" Padding="0" FontSize="12"/>
                                <HyperlinkButton Content="Open source licenses" Padding="0" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>


