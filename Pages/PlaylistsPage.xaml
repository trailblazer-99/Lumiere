<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LumiereMediaPlayer.Pages.PlaylistsPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LumiereMediaPlayer.Controls"
    xmlns:local="using:LumiereMediaPlayer.Pages"
    xmlns:models="using:LumiereMediaPlayer.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="OnPageLoaded">

    <ScrollViewer>
        <StackPanel x:Name="PageContent" Margin="{StaticResource PageContentMargin}" Spacing="28" Opacity="1">
            <!-- Header -->
            <StackPanel Spacing="6">
                <TextBlock
                    Style="{StaticResource PageTitleTextStyle}"
                    Text="Playlists" />
                <TextBlock
                    Style="{StaticResource PageSubtitleTextStyle}"
                    Text="Curated collections ready to play." />
            </StackPanel>

            <!-- Playlist grid -->
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Playlists, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MinColumnSpacing="16"
                        MinItemHeight="280"
                        MinItemWidth="220"
                        MinRowSpacing="16"
                        Orientation="Horizontal" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Style="{StaticResource CardButtonStyle}"
                            Command="{Binding ElementName=PageRoot, Path=ViewModel.PlayPlaylistCommand}"
                            CommandParameter="{Binding}">
                            <Button.Transitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="24" IsStaggeringEnabled="True" />
                                </TransitionCollection>
                            </Button.Transitions>
                            <Border
                                Style="{StaticResource MediaCardStyle}"
                                Padding="16">
                                <StackPanel Spacing="12">
                                    <controls:MediaCard
                                        AccentColor="{Binding AccentColor}"
                                        Subtitle="{Binding Description}"
                                        Title="{Binding Name}" />
                                    <TextBlock
                                        Style="{StaticResource SubtleCaptionTextStyle}"
                                        VerticalAlignment="Center"
                                        Text="{Binding TrackCountLabel}"
                                        Opacity="0.8" />
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollViewer>
</Page>

