<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LumiereMediaPlayer.Pages.VideoPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LumiereMediaPlayer.Pages"
    xmlns:models="using:LumiereMediaPlayer.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:LumiereMediaPlayer.Controls"
    xmlns:helpers="using:LumiereMediaPlayer.Helpers"
    mc:Ignorable="d"
    Loaded="OnPageLoaded">

    <Page.Resources>
        <Storyboard x:Key="AmbientAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation
                Storyboard.TargetName="AmbientRotation"
                Storyboard.TargetProperty="Angle"
                From="-10" To="10" Duration="0:1:15" />
            <DoubleAnimation
                Storyboard.TargetName="AmbientScale"
                Storyboard.TargetProperty="ScaleX"
                From="1.3" To="1.6" Duration="0:1:0" />
            <DoubleAnimation
                Storyboard.TargetName="AmbientScale"
                Storyboard.TargetProperty="ScaleY"
                From="1.3" To="1.6" Duration="0:1:0" />
        </Storyboard>
    </Page.Resources>

    <Grid x:Name="PageContent" Margin="{StaticResource PageContentMargin}" RowSpacing="16" Opacity="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Ambient "Glow" Backdrop for Video Page -->
        <Grid x:Name="AmbientArtworkHost" Opacity="0.12" Grid.RowSpan="3" IsHitTestVisible="False">
            <Image
                x:Name="AmbientArtworkImage"
                Source="{x:Bind helpers:ImageBindHelper.SafeImageFromUrl(ViewModel.CurrentPosterUrl), Mode=OneWay}"
                Stretch="UniformToFill"
                RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="AmbientScale" ScaleX="1.4" ScaleY="1.4" />
                        <RotateTransform x:Name="AmbientRotation" Angle="0" />
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
            
            <!-- Vignette blending overlay -->
            <Border>
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
                        <GradientStop Color="#00000000" Offset="0.0"/>
                        <GradientStop Color="{ThemeResource SolidBackgroundFillColorBase}" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
        </Grid>

        <!-- Header -->
        <StackPanel x:Name="HeaderPanel" Spacing="6" Visibility="{x:Bind ViewModel.OverlayVisibility, Mode=OneWay}">
            <Grid x:Name="HeaderGrid">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="HeaderRow0" Height="Auto" />
                    <RowDefinition x:Name="HeaderRow1" Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HeaderCol0" Width="*" />
                    <ColumnDefinition x:Name="HeaderCol1" Width="Auto" />
                </Grid.ColumnDefinitions>

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="HeaderLayoutStates">
                        <VisualState x:Name="WideHeader">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="900" />
                            </VisualState.StateTriggers>
                        </VisualState>
                        <VisualState x:Name="NarrowHeader">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="0" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="HeaderCol0.Width" Value="*" />
                                <Setter Target="HeaderCol1.Width" Value="*" />
                                <Setter Target="ControlsPanel.(Grid.Row)" Value="1" />
                                <Setter Target="ControlsPanel.(Grid.Column)" Value="0" />
                                <Setter Target="ControlsPanel.(Grid.ColumnSpan)" Value="2" />
                                <Setter Target="ControlsPanel.Margin" Value="0,16,0,0" />
                                <Setter Target="ControlsPanel.HorizontalAlignment" Value="Left" />
                                <Setter Target="TitlePanel.(Grid.ColumnSpan)" Value="2" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <StackPanel x:Name="TitlePanel" Grid.Column="0" Grid.Row="0">
                    <TextBlock
                        Style="{StaticResource PageTitleTextStyle}"
                        Text="Videos" />
                    <TextBlock
                        Style="{StaticResource PageSubtitleTextStyle}"
                        Text="Watch videos with native Windows playback controls." />
                </StackPanel>
                
                <StackPanel x:Name="ControlsPanel" Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                    <ComboBox
                        Width="140"
                        Header="Filter By"
                        ItemsSource="{x:Bind ViewModel.FilterExtensionOptions}"
                        SelectedItem="{x:Bind ViewModel.SelectedFilterExtension, Mode=TwoWay}" />
                    <ComboBox
                        Width="160"
                        Header="Sort By"
                        ItemsSource="{x:Bind ViewModel.SortOptions}"
                        SelectedItem="{x:Bind ViewModel.SelectedSort, Mode=TwoWay}" />
                        
                    <Button VerticalAlignment="Bottom" Command="{x:Bind ViewModel.AddFolderCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE838;" FontSize="14" />
                            <TextBlock Text="Add Folder" />
                        </StackPanel>
                    </Button>
                    <Button VerticalAlignment="Bottom" Command="{x:Bind ViewModel.AddFilesCommand}" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                            <TextBlock Text="Open File(s)" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>

                <!-- Main Library Gallery View -->
        <ScrollViewer Grid.Row="1" Visibility="{x:Bind ViewModel.OverlayVisibility, Mode=OneWay}" VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.FilteredVideos, Mode=OneWay}" Margin="0,0,0,32">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="240" MinRowSpacing="16" MinColumnSpacing="16" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Style="{StaticResource CardButtonStyle}"
                            Command="{Binding ElementName=PageRoot, Path=ViewModel.PlayVideoCommand}"
                            CommandParameter="{Binding}">
                            <Button.Transitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="32" IsStaggeringEnabled="True" />
                                </TransitionCollection>
                            </Button.Transitions>
                            <controls:MediaCard
                                CardWidth="150"
                                CardHeight="225"
                                AccentColor="{Binding AccentColor}"
                                Artwork="{Binding Artwork}"
                                PosterUrl="{Binding PosterUrl}"
                                Subtitle="{Binding ReleaseYear}"
                                Title="{Binding Title}" />
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Player & Sidebar Layout -->
        <Grid Grid.Row="1" ColumnSpacing="16" Visibility="{x:Bind ViewModel.PlayerVisibility, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Video player container -->
            <Border
                x:Name="VideoPlayerContainer"
                Grid.Column="0"
                Background="#FF000000"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource LargeCornerRadius}"
                DoubleTapped="OnVideoDoubleTapped"
                Tapped="OnVideoTapped"
                PointerWheelChanged="OnVideoPointerWheelChanged">
                <Grid x:Name="VideoPlayerHost" Background="#FF000000" SizeChanged="OnVideoPlayerHostSizeChanged">
                    <MediaPlayerElement x:Name="LocalVideoPlayer" x:FieldModifier="public" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" AreTransportControlsEnabled="False" AutoPlay="False" />
                    <Rectangle Fill="Transparent" IsHitTestVisible="True" />

                    <!-- HDR Status Badge -->
                    <Border
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="16"
                        Padding="8,4"
                        CornerRadius="4"
                        Visibility="{x:Bind ViewModel.HdrBadgeVisibility, Mode=OneWay}"
                        Background="#CC000000">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon
                                FontSize="11"
                                Glyph="&#xE7DE;"
                                Foreground="#FFE6C800"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Text="{x:Bind ViewModel.HdrContentLabel, Mode=OneWay}"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#FFE6C800"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Metadata Overlay -->
                    <Border
                        x:Name="MetadataOverlay"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="24"
                        Padding="20"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Background="{ThemeResource LayerFillColorAltBrush}">
                        <Border.BackgroundTransition>
                            <BrushTransition />
                        </Border.BackgroundTransition>
                        <StackPanel Spacing="24" MaxWidth="350">
                            <!-- File Info -->
                            <StackPanel Spacing="12">
                                <TextBlock Text="File Information" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                
                                <Grid ColumnSpacing="24" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Resolution" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.CurrentVideo.Resolution, Mode=OneWay, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Codec" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.CurrentVideo.Codec, Mode=OneWay, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Bitrate" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.CurrentVideo.BitrateText, Mode=OneWay, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Framerate" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.CurrentVideo.FrameRateText, Mode=OneWay, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="File Size" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.CurrentVideo.FileSizeText, Mode=OneWay, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="File Path" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.CurrentVideo.SourcePath, Mode=OneWay, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" MaxWidth="250" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Grid>
                            </StackPanel>

                            <!-- Internet Metadata Match -->
                            <StackPanel x:Name="InternetMetadataPanel" Spacing="12" Visibility="Collapsed">
                                <TextBlock Text="Internet Match" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                <ProgressRing x:Name="InternetMetadataProgress" IsActive="False" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,20,0,20"/>
                                
                                <Grid x:Name="InternetMetadataContent" ColumnSpacing="12" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image x:Name="InternetMetadataPoster" Stretch="UniformToFill" VerticalAlignment="Top" />
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock x:Name="InternetMetadataTitle" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="InternetMetadataOverview" TextWrapping="Wrap" MaxLines="4" TextTrimming="CharacterEllipsis" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel x:Name="InternetMetadataProvidersPanel" Spacing="8" Visibility="Collapsed">
                                    <TextBlock Text="Available on:" FontWeight="SemiBold" FontSize="14"/>
                                    <Grid x:Name="InternetMetadataProvidersGrid" ColumnSpacing="8" RowSpacing="8"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Video list sidebar -->
            <Border
                x:Name="VideoListBorder"
                Grid.Column="1"
                CornerRadius="{StaticResource CardCornerRadiusFull}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="4">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Up Next" Style="{StaticResource SectionHeaderTextStyle}" Margin="12,12,12,4"/>
                    
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.FilteredVideos, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition />
                                <ContentThemeTransition />
                                <ReorderThemeTransition />
                            </TransitionCollection>
                        </ListView.ItemContainerTransitions>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MediaItem">
                                <Grid Padding="12,10" ColumnSpacing="12" Tapped="OnVideoItemTapped" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                      <!-- Video Poster Thumbnail -->
                                      <Border
                                          Grid.Column="0"
                                          Width="36"
                                          Height="54"
                                          CornerRadius="4"
                                          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                          VerticalAlignment="Center">
                                          <Grid>
                                              <FontIcon
                                                  FontSize="14"
                                                  Glyph="&#xE714;"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Opacity="0.5" />
                                              <Image Source="{Binding PosterUrl}" Stretch="UniformToFill" />
                                          </Grid>
                                      </Border>

                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="{Binding Title}"
                                            MaxLines="1"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Style="{StaticResource SubtleCaptionTextStyle}"
                                            Text="{Binding Artist}"
                                            MaxLines="1"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Button
                                        Grid.Column="2"
                                        AutomationProperties.Name="Play video"
                                        Command="{Binding ElementName=PageRoot, Path=ViewModel.PlayVideoCommand}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource TransportIconButtonStyle}"
                                        ToolTipService.ToolTip="Play">
                                        <FontIcon FontSize="14" Glyph="&#xE768;" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Page>


