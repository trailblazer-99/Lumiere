<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluentMediaPlayer.Pages.StreamingTwitchPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:streaming="using:FluentMediaPlayer.Services.Streaming"
    mc:Ignorable="d"
    Loaded="OnPageLoaded"
    Unloaded="OnPageUnloaded">

    <Grid x:Name="PageContent" Margin="{StaticResource PageContentMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <FontIcon Glyph="&#xE7FC;" FontSize="32" Foreground="#D85AFF"/> <!-- Twitch Purple -->
                    <TextBlock Text="Twitch" Style="{StaticResource PageTitleTextStyle}"/>
                </StackPanel>
                <TextBlock Text="Watch Twitch live streams and VODs in a seamless media wrapper."
                           Style="{StaticResource PageSubtitleTextStyle}"
                           Opacity="0.7"/>
            </StackPanel>

            <!-- Twitch API Credentials Setup -->
            <Expander Grid.Column="1" Header="Twitch Helix Settings" HorizontalAlignment="Right" VerticalAlignment="Top" ExpandDirection="Down">
                <StackPanel Spacing="8" Padding="12" Width="320">
                    <TextBox x:Name="ClientIdTextBox" Header="Twitch Client ID" IsReadOnly="True" />
                    <PasswordBox x:Name="ClientSecretInput" Header="Twitch Client Secret" PasswordChanged="OnClientSecretChanged" PasswordChar="●"/>
                    <TextBlock Text="Note: Helix API queries require a client secret. Keys persist locally." FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>
        </Grid>

        <!-- Search Bar and Section Title -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="0"
                PlaceholderText="Search channels, live streamers, games..."
                QueryIcon="Find"
                QuerySubmitted="OnSearchQuerySubmitted"
                MinWidth="400"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"/>

            <Button x:Name="BackButton" Grid.Column="1" Click="OnBackClick" Visibility="Collapsed" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Back"/>
                    <TextBlock Text="Back to listings"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="2">
            <!-- Loading indicator -->
            <ProgressRing x:Name="LoadingRing" IsActive="False"
                          Width="48" Height="48"
                          HorizontalAlignment="Center" VerticalAlignment="Center" Canvas.ZIndex="10"/>

            <!-- Info Bar for setup warnings -->
            <InfoBar x:Name="CredentialsWarningBar" Severity="Warning" Title="Credentials Required" 
                     Message="Twitch Client Secret is missing. Please configure it in Helix Settings to fetch live lists and searches."
                     IsOpen="False" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,0,0,12" Canvas.ZIndex="5"/>

            <!-- Listings / Grid View (Active Streams, Search Profiles, or VODs) -->
            <ScrollViewer x:Name="MainScrollArea" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="24" Margin="0,0,0,16">
                    <TextBlock x:Name="SectionTitle" Text="Top Live Streams" Style="{StaticResource TitleTextBlockStyle}" FontWeight="SemiBold" FontSize="20"/>

                    <GridView x:Name="TwitchGridView"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="OnGridItemClick"
                              HorizontalAlignment="Stretch">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1" ItemWidth="280"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="streaming:TwitchSearchResult">
                                <Grid Margin="0,0,12,16" Padding="8" Width="268" Height="240" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Thumbnail and badges -->
                                    <Grid Grid.Row="0" Width="252" Height="142" CornerRadius="6">
                                        <Border CornerRadius="6">
                                            <Border.Background>
                                                <ImageBrush Stretch="UniformToFill" ImageSource="{x:Bind ThumbnailImage}"/>
                                            </Border.Background>
                                        </Border>

                                        <!-- Live Badge -->
                                        <Border Background="#FFFF0000" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" Visibility="{x:Bind LiveVisibility}">
                                            <!-- We can bind visibility directly in code or fallback properties -->
                                            <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        
                                        <!-- Viewers / duration badge -->
                                        <Border Background="#CC000000" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8">
                                            <TextBlock Text="{x:Bind ViewerCountStr}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>

                                    <!-- Information Info -->
                                    <StackPanel Grid.Row="1" Margin="4,8,4,0" Spacing="4">
                                        <TextBlock Text="{x:Bind Title}" FontSize="13" FontWeight="SemiBold" MaxLines="2" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                                        <TextBlock Text="{x:Bind DisplayName}" FontSize="12" Opacity="0.8"/>
                                        <TextBlock Text="{x:Bind GameName}" FontSize="11" Opacity="0.6" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>

                    <!-- Streamer VODs Listing Panel (Shown when displaying channel details) -->
                    <StackPanel x:Name="VodsPanel" Spacing="12" Visibility="Collapsed">
                        <TextBlock Text="Recent Videos &amp; VODs" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" FontSize="16"/>
                        <GridView x:Name="VodsGridView"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="OnVodItemClick"
                                  HorizontalAlignment="Stretch">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1" ItemWidth="280"/>
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="streaming:TwitchSearchResult">
                                    <Grid Margin="0,0,12,16" Padding="8" Width="268" Height="240" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Thumbnail and Duration -->
                                        <Grid Grid.Row="0" Width="252" Height="142" CornerRadius="6">
                                            <Border CornerRadius="6">
                                                <Border.Background>
                                                    <ImageBrush Stretch="UniformToFill" ImageSource="{x:Bind ThumbnailImage}"/>
                                                </Border.Background>
                                            </Border>

                                            <!-- VOD Duration Badge -->
                                            <Border Background="#CC000000" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8">
                                                <TextBlock Text="{x:Bind Duration}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>

                                        <!-- VOD Info -->
                                        <StackPanel Grid.Row="1" Margin="4,8,4,0" Spacing="4">
                                            <TextBlock Text="{x:Bind Title}" FontSize="13" FontWeight="SemiBold" MaxLines="2" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind PublishedDate}" FontSize="12" Opacity="0.8"/>
                                            <TextBlock Text="{x:Bind VideoType}" FontSize="11" Opacity="0.6"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Hybrid WebView2 Twitch Player Overlay -->
            <Grid x:Name="PlayerOverlay" Visibility="Collapsed" Background="Black">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Host where WebView2 browser is dynamically inserted -->
                <Grid x:Name="WebViewContainer" Grid.Row="0" Background="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <!-- Native Player Controls Panel -->
                <Grid x:Name="NativeControlsPanel" Grid.Row="1" Padding="20,16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                    <Grid.Background>
                        <AcrylicBrush TintColor="{ThemeResource SolidBackgroundFillColorBase}" TintOpacity="0.75" FallbackColor="{ThemeResource SolidBackgroundFillColorBase}"/>
                    </Grid.Background>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Now playing stream information details -->
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border x:Name="LiveIndicatorBadge" Background="#FFFF0000" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock x:Name="NowPlayingChannel" FontSize="14" FontWeight="SemiBold" MaxLines="1" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="NowPlayingTitle" FontSize="12" Opacity="0.6" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Center: Play/Pause controls & Volume Mute -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="PlayPauseButton" Width="40" Height="40" CornerRadius="20"
                                Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="Play/Pause" Click="OnPlayPauseClick">
                            <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE769;" FontSize="16"/>
                        </Button>
                        <Button x:Name="MuteButton" Width="40" Height="40" CornerRadius="20"
                                Style="{ThemeResource DefaultButtonStyle}" ToolTipService.ToolTip="Mute/Unmute" Click="OnMuteClick">
                            <FontIcon x:Name="MuteIcon" Glyph="&#xE74F;" FontSize="16"/> <!-- Speaker volume icon -->
                        </Button>
                    </StackPanel>

                    <!-- Right: Quality selector combobox and Close Button -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Quality selector -->
                        <ComboBox x:Name="QualityComboBox" Header="" MinWidth="120" ToolTipService.ToolTip="Stream Quality" SelectionChanged="OnQualitySelectionChanged">
                            <!-- Items populated dynamically from Javascript bridge -->
                        </ComboBox>
                        
                        <Button Click="OnStopClick" Width="40" Height="40" CornerRadius="20" ToolTipService.ToolTip="Stop and Close" Style="{ThemeResource DefaultButtonStyle}">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#FFE81123"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFF14C4C"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFA80A17"/>
                                <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                            </Button.Resources>
                            <FontIcon Glyph="&#xE73B;" FontSize="14" Foreground="White"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
