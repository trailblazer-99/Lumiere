<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LumiereMediaPlayer.Pages.StreamingTvShowsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LumiereMediaPlayer.Models.Streaming"
    xmlns:services="using:LumiereMediaPlayer.Services.Streaming"
    Loaded="OnPageLoaded">

    <Grid x:Name="PageContent" Margin="{StaticResource PageContentMargin}" Opacity="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE7F4;" FontSize="32"/>
                <TextBlock Text="TV Shows" Style="{StaticResource PageTitleTextStyle}"/>
            </StackPanel>
            <TextBlock Text="Discover and stream the latest TV shows via Watchmode."
                       Style="{StaticResource PageSubtitleTextStyle}"
                       Opacity="0.7"/>
        </StackPanel>

        <Pivot x:Name="MainPivot" Grid.Row="1" SelectionChanged="MainPivot_SelectionChanged">
            <PivotItem Header="Discover">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <AutoSuggestBox x:Name="SearchBox" QueryIcon="Find" PlaceholderText="Search TV shows..." TextChanged="OnSearchBoxTextChanged" QuerySubmitted="OnSearchBoxQuerySubmitted" Width="280" VerticalAlignment="Bottom" />
                            <ComboBox Header="Region" ItemsSource="{x:Bind ViewModel.RegionOptions, Mode=OneWay}" SelectedValuePath="Code" SelectedValue="{x:Bind ViewModel.SelectedRegion, Mode=TwoWay}" SelectionChanged="RegionComboBox_SelectionChanged" DropDownClosed="RegionComboBox_DropDownClosed" Width="160" VerticalAlignment="Bottom" />
                            <ComboBox Header="Genre" ItemsSource="{x:Bind ViewModel.GenreOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedGenre, Mode=TwoWay}" Width="140" VerticalAlignment="Bottom" />
                            <ComboBox Header="Access Type" ItemsSource="{x:Bind ViewModel.AccessTypeOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedAccessType, Mode=TwoWay}" Width="130" VerticalAlignment="Bottom" />
                            <ComboBox Header="Sort by" ItemsSource="{x:Bind ViewModel.SortOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedSortOrder, Mode=TwoWay}" Width="120" VerticalAlignment="Bottom" />
                        </StackPanel>
                    </ScrollViewer>

                    <InfoBar Grid.Row="1"
                             Severity="Error"
                             Title="Connection Failed"
                             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                             Margin="0,0,0,16" />

                    <Grid Grid.Row="2">
                        <GridView x:Name="TvShowsGridView" ItemsSource="{x:Bind ViewModel.TvShows, Mode=OneWay}" IsItemClickEnabled="True" ItemClick="OnTvShowClicked" SelectionMode="None">
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                     <Setter Property="Margin" Value="0"/>
                                     <Setter Property="Padding" Value="12"/>
                                     <Setter Property="Background" Value="Transparent"/>
                                     <Setter Property="BorderThickness" Value="0"/>
                                     <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                     <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:WatchmodeTitle">
                                    <Border Width="220" Height="330" CornerRadius="12" Translation="0,0,16"
                                          Background="{ThemeResource LayerFillColorDefaultBrush}"
                                          BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                          PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                                        <Border.Shadow>
                                            <ThemeShadow />
                                        </Border.Shadow>
                                        <Grid>
                                            <Image Source="{Binding PosterUrl}" Stretch="UniformToFill" />
                                            <Border x:Name="HoverOverlay" Opacity="0.0" CornerRadius="8">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#44000000" Offset="0.0"/>
                                                        <GradientStop Color="#BB000000" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid>
                                                    <Border Width="56" Height="56" CornerRadius="28" Background="#88000000" BorderBrush="#AAFFFFFF" BorderThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <FontIcon FontSize="24" Foreground="White" Glyph="&#xE768;" Margin="3,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Height="100">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="Transparent" Offset="0"/>
                                                        <GradientStop Color="#D9000000" Offset="0.6"/>
                                                        <GradientStop Color="#FF000000" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel VerticalAlignment="Bottom" Padding="12,12,12,16">
                                                    <TextBlock Text="{x:Bind DisplayTitle, Mode=OneWay}" Foreground="White" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{x:Bind DisplayYear, Mode=OneWay}" Foreground="#E0E0E0" FontSize="13" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                        
                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Pagination Controls -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24" Margin="0,16,0,16">
                        <Button Content="Previous Page" Command="{x:Bind ViewModel.PreviousPageCommand}" IsEnabled="{x:Bind ViewModel.CanGoPrevious, Mode=OneWay}" Style="{StaticResource DefaultButtonStyle}"/>
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Page " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.CurrentPage, Mode=OneWay}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Button Content="Next Page" Command="{x:Bind ViewModel.NextPageCommand}" IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}" Style="{StaticResource DefaultButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </PivotItem>
            
            <PivotItem Header="Library">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <ComboBox x:Name="LibraryFilterComboBox" Header="Watchlist Category" Width="180" SelectionChanged="OnLibraryFilterChanged">
                            <ComboBoxItem Content="All" IsSelected="True" />
                            <ComboBoxItem Content="Watchlist" />
                            <ComboBoxItem Content="Plan to Watch" />
                            <ComboBoxItem Content="Watching" />
                            <ComboBoxItem Content="Completed" />
                            <ComboBoxItem Content="Favorites" />
                        </ComboBox>
                    </StackPanel>

                    <GridView Grid.Row="1" x:Name="LibraryGridView" IsItemClickEnabled="True" ItemClick="LibraryGridView_ItemClick" SelectionMode="None">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Padding" Value="12"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="services:SavedStreamingItem">
                                <Border Width="220" Height="330" CornerRadius="12" Translation="0,0,16"
                                      Background="{ThemeResource LayerFillColorDefaultBrush}"
                                      BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                      PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                                    <Border.Shadow>
                                        <ThemeShadow />
                                    </Border.Shadow>
                                    <Grid>
                                        <Image Source="{Binding PosterUrl}" Stretch="UniformToFill" />
                                        <Border x:Name="HoverOverlay" Opacity="0.0" CornerRadius="8">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#44000000" Offset="0.0"/>
                                                    <GradientStop Color="#BB000000" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <Border Width="56" Height="56" CornerRadius="28" Background="#88000000" BorderBrush="#AAFFFFFF" BorderThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <FontIcon FontSize="24" Foreground="White" Glyph="&#xE768;" Margin="3,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <Border VerticalAlignment="Bottom" Height="100">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#D9000000" Offset="0.6"/>
                                                    <GradientStop Color="#FF000000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel VerticalAlignment="Bottom" Padding="12,12,12,16">
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Subtitle}" Foreground="#E0E0E0" FontSize="13" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Grid>
            </PivotItem>

            <PivotItem Header="Catalog Changes">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Recent updates and new additions in the streaming catalog." Style="{StaticResource BodyTextBlockStyle}" Opacity="0.7" />
                    </StackPanel>

                    <ListView Grid.Row="1" x:Name="CatalogChangesListView" IsItemClickEnabled="True" ItemClick="OnCatalogChangeItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12" Margin="0,4,0,4" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <Border Background="#107C41" CornerRadius="4" Padding="6,2,6,2" VerticalAlignment="Center">
                                            <TextBlock Text="UPDATED" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
