<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LumiereMediaPlayer.Pages.NowPlayingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LumiereMediaPlayer.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:LumiereMediaPlayer.Helpers"
    mc:Ignorable="d"
    Loaded="OnPageLoaded">

    <Page.Resources>
        <Storyboard x:Key="AmbientAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation
                Storyboard.TargetName="AmbientRotation"
                Storyboard.TargetProperty="Angle"
                From="-12" To="12" Duration="0:1:10" />
            <DoubleAnimation
                Storyboard.TargetName="AmbientScale"
                Storyboard.TargetProperty="ScaleX"
                From="1.3" To="1.6" Duration="0:0:55" />
            <DoubleAnimation
                Storyboard.TargetName="AmbientScale"
                Storyboard.TargetProperty="ScaleY"
                From="1.3" To="1.6" Duration="0:0:55" />
        </Storyboard>
    </Page.Resources>

    <!-- Background gradient overlay — derived from accent color in code-behind -->
    <Grid x:Name="PageRoot">
        <!-- Ambient "Glow" Backdrop -->
        <Grid x:Name="AmbientArtworkHost" Opacity="0.14">
            <Image
                x:Name="AmbientArtworkImage"
                Source="{x:Bind helpers:ImageBindHelper.SafeImageFromUrl(ViewModel.PosterUrl), Mode=OneWay}"
                Stretch="UniformToFill"
                RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="AmbientScale" ScaleX="1.4" ScaleY="1.4" />
                        <RotateTransform x:Name="AmbientRotation" Angle="0" />
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
            
            <!-- Radial overlay to blend edges with solid dark theme background -->
            <Border>
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
                        <GradientStop Color="#00000000" Offset="0.0"/>
                        <GradientStop Color="{ThemeResource SolidBackgroundFillColorBase}" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
        </Grid>

        <Border
            x:Name="AccentGradientOverlay"
            Opacity="0.08">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="GradientStart" Offset="0.0" />
                    <GradientStop Color="Transparent" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="{StaticResource PageContentMargin}" x:Name="ContentGrid" Opacity="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Album art — left column -->
            <StackPanel
                Grid.Column="0"
                Margin="0,0,40,0"
                Spacing="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <Grid Width="340" Height="340">
                    <!-- Actual album art with true Fluent Design 2 ThemeShadow -->
                    <Border
                        x:Name="HeroAlbumArt"
                        Width="340"
                        Height="340"
                        CornerRadius="{StaticResource LargeCornerRadius}"
                        Translation="0,0,16"
                        RenderTransformOrigin="0.5,0.5">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <Grid CornerRadius="{StaticResource LargeCornerRadius}">
                            <FontIcon
                                FontSize="100"
                                Foreground="White"
                                Glyph="&#xE8D6;"
                                HorizontalAlignment="Center"
                                Opacity="0.85"
                                VerticalAlignment="Center" />
                            <Image
                                x:Name="AlbumArtImage"
                                Source="{x:Bind helpers:ImageBindHelper.SafeImageFromUrl(ViewModel.PosterUrl), Mode=OneWay}"
                                Stretch="UniformToFill" />
                        </Grid>
                    </Border>

                    <!-- Metadata Overlay -->
                    <Border
                        x:Name="MetadataOverlay"
                        Width="340"
                        Height="340"
                        CornerRadius="{StaticResource LargeCornerRadius}"
                        Background="{ThemeResource LayerFillColorAltBrush}"
                        Visibility="Collapsed">
                        <Border.BackgroundTransition>
                            <BrushTransition />
                        </Border.BackgroundTransition>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="InternetMetadataPanel" Padding="20" Spacing="12" />
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Audio Visualizer Panel -->
                <StackPanel
                    x:Name="VisualizerContainer"
                    Orientation="Horizontal"
                    Spacing="8"
                    Height="64"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom">
                    <StackPanel.Resources>
                        <Style TargetType="Rectangle">
                            <Setter Property="Width" Value="8" />
                            <Setter Property="Height" Value="6" />
                            <Setter Property="Fill" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                            <Setter Property="RadiusX" Value="4" />
                            <Setter Property="RadiusY" Value="4" />
                            <Setter Property="VerticalAlignment" Value="Bottom" />
                        </Style>
                    </StackPanel.Resources>
                    <Rectangle x:Name="Bar0" />
                    <Rectangle x:Name="Bar1" />
                    <Rectangle x:Name="Bar2" />
                    <Rectangle x:Name="Bar3" />
                    <Rectangle x:Name="Bar4" />
                    <Rectangle x:Name="Bar5" />
                    <Rectangle x:Name="Bar6" />
                    <Rectangle x:Name="Bar7" />
                    <Rectangle x:Name="Bar8" />
                    <Rectangle x:Name="Bar9" />
                    <Rectangle x:Name="Bar10" />
                    <Rectangle x:Name="Bar11" />
                    <Rectangle x:Name="Bar12" />
                    <Rectangle x:Name="Bar13" />
                    <Rectangle x:Name="Bar14" />
                    <Rectangle x:Name="Bar15" />
                </StackPanel>
            </StackPanel>

            <!-- Track info — right column -->
            <StackPanel
                Grid.Column="1"
                x:Name="TrackInfoPanel"
                Spacing="8"
                VerticalAlignment="Center">

                <!-- Now playing badge -->
                <Border
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="{StaticResource SmallCornerRadius}"
                    HorizontalAlignment="Left"
                    Padding="10,4">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                        CharacterSpacing="80"
                        Text="NOW PLAYING" />
                </Border>

                <!-- Title -->
                <TextBlock
                    Style="{StaticResource DisplayTextStyle}"
                    Margin="0,8,0,0"
                    Text="{x:Bind ViewModel.Title, Mode=OneWay}" />

                <!-- Artist -->
                <TextBlock
                    FontSize="18"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.Artist, Mode=OneWay}" />

                <!-- Album -->
                <TextBlock
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Margin="0,0,0,8"
                    Text="{x:Bind ViewModel.Album, Mode=OneWay}" />

                <!-- Lyrics card -->
                <Border
                    x:Name="LyricsCard"
                    Margin="0,16,0,0"
                    Padding="16"
                    Height="240"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadiusFull}"
                    Opacity="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon
                                    FontSize="14"
                                    Glyph="&#xEA37;"
                                    Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                <TextBlock
                                    FontWeight="SemiBold"
                                    FontSize="13"
                                    Text="Lyrics" />
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="TranslateLyricsButton" Click="OnTranslateLyricsClick" ToolTipService.ToolTip="Translate Lyrics" Style="{StaticResource TransportIconButtonStyle}" Height="28" Width="28" Visibility="Collapsed" VerticalAlignment="Center">
                                <FontIcon FontSize="12" Glyph="&#xE8C8;"/>
                            </Button>
                        </Grid>

                        <!-- Placeholder when no lyrics -->
                        <TextBlock
                            x:Name="NoLyricsPlaceholder"
                            Grid.Row="1"
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            LineHeight="22"
                            Text="Lyrics will appear here when available (.lrc file next to audio)."
                            TextWrapping="WrapWholeWords"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextAlignment="Center" />

                        <!-- Synced Lyrics ListView -->
                        <ListView
                            x:Name="LyricsListView"
                            Grid.Row="1"
                            SelectionMode="None"
                            IsItemClickEnabled="True"
                            ItemClick="OnLyricsLineClick"
                            ScrollViewer.VerticalScrollBarVisibility="Hidden"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            Visibility="Collapsed">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,4" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="2" Margin="0,4" HorizontalAlignment="Center">
                                        <TextBlock
                                            x:Name="LyricText"
                                            Text="{Binding Text}"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            TextWrapping="Wrap"
                                            TextAlignment="Center"
                                            HorizontalAlignment="Center" />
                                        <TextBlock
                                            x:Name="LyricTranslationText"
                                            Text="{Binding Translation}"
                                            Visibility="{Binding HasTranslation}"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            TextAlignment="Center"
                                            HorizontalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
