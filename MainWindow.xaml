<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="LumiereMediaPlayer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LumiereMediaPlayer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LumiereMediaPlayer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Lumière Media Player">


    <Grid x:Name="RootGrid" Loaded="OnWindowLoaded" KeyDown="OnRootGridKeyDown" PointerWheelChanged="OnRootGridPointerWheelChanged" PointerMoved="OnRootGridPointerMoved" PointerPressed="OnRootGridPointerPressed" PointerReleased="OnRootGridPointerReleased">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <NavigationView
            x:Name="RootNavigationView"
            Grid.Row="0"
            IsBackButtonVisible="Visible"
            IsSettingsVisible="True"
            PaneDisplayMode="Left"
            SelectionChanged="OnNavigationSelectionChanged"
            BackRequested="OnBackRequested"
            PaneOpened="OnNavigationPaneOpened"
            PaneClosed="OnNavigationPaneClosed"
            PaneOpening="OnNavigationPaneOpening"
            PaneClosing="OnNavigationPaneClosing"
            DisplayModeChanged="OnNavigationDisplayModeChanged">

            <NavigationView.AutoSuggestBox>
                <AutoSuggestBox
                    x:Name="AppSearchBox"
                    PlaceholderText="Search music, videos, streaming..."
                    QueryIcon="Find"
                    TextChanged="OnSearchTextChanged"
                    QuerySubmitted="OnSearchQuerySubmitted"
                    SuggestionChosen="OnSearchSuggestionChosen" />
            </NavigationView.AutoSuggestBox>

            <NavigationView.Resources>
                <Thickness x:Key="NavigationViewHeaderMargin">0</Thickness>
                <Thickness x:Key="NavigationViewContentMargin">0</Thickness>
                <Thickness x:Key="NavigationViewMinimalContentMargin">0</Thickness>
                <x:Double x:Key="NavigationViewHeaderMinHeight">0</x:Double>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
            </NavigationView.Resources>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Icon="Home" Tag="home" />
                <NavigationViewItem Content="Music" Icon="MusicInfo" Tag="music" />
                <NavigationViewItem Content="Videos" Icon="Video" Tag="videos" />
                <NavigationViewItem Content="Playlists" Icon="List" Tag="playlists" />
                <NavigationViewItem
                    x:Name="NowPlayingNavItem"
                    Content="Now playing"
                    Icon="Play"
                    Tag="nowPlaying">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="PlaybackInfoBadge" Visibility="Collapsed">
                            <InfoBadge.IconSource>
                                <SymbolIconSource Symbol="Play" />
                            </InfoBadge.IconSource>
                        </InfoBadge>
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="Streaming" Tag="streaming">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE93E;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Music" Tag="streamMusic">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8D6;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="Movies" Tag="streamMovies">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8B2;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="TV Shows" Tag="streamTvShows">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7F4;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="YouTube" Tag="streamYouTube">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE714;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="Twitch" Tag="streamTwitch">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7FC;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Margin="0" Navigated="OnContentFrameNavigated">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Height="48"
            VerticalAlignment="Top"
            PointerEntered="OnControlsPointerEntered"
            PointerExited="OnControlsPointerExited">
            <Grid.ColumnDefinitions>
                <!-- Hamburger button spacer / Back button area -->
                <ColumnDefinition Width="48" />
                <!-- Window drag region -->
                <ColumnDefinition Width="*" />
                <!-- Custom Fullscreen Button -->
                <ColumnDefinition Width="Auto" />
                <!-- Right padding for system window caption buttons -->
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <!-- Custom back button for video overlay mode -->
            <Button
                x:Name="VideoBackButton"
                Grid.Column="0"
                Width="36"
                Height="36"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#CC1F1F1F"
                BorderBrush="#20FFFFFF"
                BorderThickness="1"
                CornerRadius="6"
                Click="OnVideoBackButtonClick"
                Visibility="Collapsed"
                Translation="0,0,8"
                ToolTipService.ToolTip="Back">
                <Button.Shadow>
                    <ThemeShadow />
                </Button.Shadow>
                <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="White" />
            </Button>

            <!-- Hit-testable drag region -->
            <Grid
                x:Name="DragRegion"
                Grid.Column="1"
                Background="Transparent"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <StackPanel x:Name="TitleBrandPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Width="20" Height="20" Source="ms-appx:///Assets/LumiereIcon.png" VerticalAlignment="Center" Stretch="Uniform" />
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Lumière Media Player"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Custom Fullscreen Button next to caption buttons (styled to match native size) -->
            <Button
                x:Name="TitleBarFullscreenButton"
                Grid.Column="2"
                Width="46"
                Height="48"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Click="OnTitleBarFullscreenButtonClick"
                ToolTipService.ToolTip="Toggle Full Screen (F11)">
                <FontIcon Glyph="&#xE740;" FontSize="11" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Button>
        </Grid>

        <!-- The Fullscreen Video Container -->
        <Grid x:Name="FullscreenVideoContainer" Visibility="Collapsed" Background="#FF000000" Grid.RowSpan="2" DoubleTapped="OnVideoDoubleTapped" Tapped="OnVideoTapped" PointerWheelChanged="OnVideoPointerWheelChanged" SizeChanged="OnFullscreenVideoContainerSizeChanged">


            <!-- Fullscreen Controls Overlay — sits above video, fades in/out -->
            <Grid x:Name="FullscreenControlsOverlay" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- top bar: back button -->
                    <RowDefinition Height="*"/>      <!-- transparent middle (hit-test pass-through) -->
                    <RowDefinition Height="Auto"/>   <!-- bottom bar: transport + scrim -->
                </Grid.RowDefinitions>

                <!-- Top gradient scrim + back button -->
                <Grid Grid.Row="0" Height="72">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Button
                        x:Name="FullscreenBackButton"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="16"
                        Width="36" Height="36"
                        Background="#40000000"
                        BorderBrush="#30FFFFFF"
                        BorderThickness="1"
                        CornerRadius="6"
                        Click="OnVideoBackButtonClick"
                        ToolTipService.ToolTip="Exit video">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="White"/>
                    </Button>
                </Grid>

                <!-- Middle: transparent, lets taps through to the video -->
                <Grid Grid.Row="1" Background="Transparent" IsHitTestVisible="False"/>

                <!-- Bottom transport controls slot -->
                <Grid Grid.Row="2" Background="Transparent">
                    <!-- TransportBar is reparented here at runtime via FullscreenTransportHost -->
                    <Border x:Name="FullscreenTransportHost" />
                </Grid>
            </Grid>

            <!-- Metadata Overlay -->
            <Border
                x:Name="FullscreenMetadataOverlay"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="24"
                Padding="20"
                CornerRadius="8"
                Visibility="Collapsed"
                Background="#CC1F1F1F">
                <Border.BackgroundTransition>
                    <BrushTransition />
                </Border.BackgroundTransition>
                <StackPanel Spacing="12">
                    <TextBlock Text="File Information" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="White" />
                    
                    <Grid ColumnSpacing="24" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Resolution" Foreground="#A0A0A0" FontSize="12" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Playback.CurrentTrack.Resolution, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="White" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Codec" Foreground="#A0A0A0" FontSize="12" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Playback.CurrentTrack.Codec, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="White" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Bitrate" Foreground="#A0A0A0" FontSize="12" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Playback.CurrentTrack.BitrateText, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="White" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Framerate" Foreground="#A0A0A0" FontSize="12" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Playback.CurrentTrack.FrameRateText, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="White" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="File Size" Foreground="#A0A0A0" FontSize="12" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Playback.CurrentTrack.FileSizeText, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="White" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="File Path" Foreground="#A0A0A0" FontSize="12" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Playback.CurrentTrack.SourcePath, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" MaxWidth="250" TextWrapping="Wrap" Foreground="White" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <controls:TransportBar
            x:Name="TransportControls"
            Grid.Row="1"
            PointerEntered="OnControlsPointerEntered"
            PointerExited="OnControlsPointerExited"
            PointerWheelChanged="OnTransportControlsPointerWheelChanged"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom" />

        <!-- Mini Player View (CompactOverlay Mode) -->
        <Grid
            x:Name="MiniPlayerGrid"
            Grid.Row="0"
            Grid.RowSpan="2"
            Background="#FF111111"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.Resources>
                <!-- Custom Circular Icon Button Style -->
                <Style x:Key="MiniIconButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Width" Value="44"/>
                    <Setter Property="Height" Value="44"/>
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="RootGrid" Background="Transparent" CornerRadius="22" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                                    </Grid.RenderTransform>
                                    
                                    <!-- Hover background circle -->
                                    <Ellipse x:Name="HoverCircle" Fill="White" Opacity="0.0" Width="40" Height="40"/>
                                    
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverCircle" Storyboard.TargetProperty="Opacity" To="0.0" Duration="0:0:0.1" />
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1" />
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1" />
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="PointerOver">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverCircle" Storyboard.TargetProperty="Opacity" To="0.1" Duration="0:0:0.1" />
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.05" Duration="0:0:0.1" />
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.05" Duration="0:0:0.1" />
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Pressed">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HoverCircle" Storyboard.TargetProperty="Opacity" To="0.2" Duration="0:0:0.05" />
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="0.95" Duration="0:0:0.05" />
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="0.95" Duration="0:0:0.05" />
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- Large Custom Play/Pause Button Style -->
                <Style x:Key="MiniPlayPauseButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Width" Value="64"/>
                    <Setter Property="Height" Value="64"/>
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="RootGrid" Background="Transparent" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                                    </Grid.RenderTransform>
                                    
                                    <!-- Outer Gradient Ring -->
                                    <Border x:Name="OuterRing"
                                            Width="60"
                                            Height="60"
                                            CornerRadius="30"
                                            BorderThickness="3.5">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFFF7E40" Offset="0.0" />
                                                <GradientStop Color="#FFFF2D55" Offset="0.5" />
                                                <GradientStop Color="#FF8E52E8" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        
                                        <!-- Inner Circle -->
                                        <Grid x:Name="InnerCircle"
                                              CornerRadius="27"
                                              Background="#FF2A2A2D">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1" />
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1" />
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="PointerOver">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.06" Duration="0:0:0.1" />
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.06" Duration="0:0:0.1" />
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Pressed">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="0.94" Duration="0:0:0.05" />
                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="0.94" Duration="0:0:0.05" />
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <!-- Center Control Area -->
            <Grid Grid.Row="1">
                <!-- Video Player (Video mode) -->
                <MediaPlayerElement x:Name="MiniVideoPlayer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" AreTransportControlsEnabled="False" Stretch="Uniform" Visibility="Collapsed" />
                
                <!-- Album Art (Audio mode) -->
                <Image x:Name="MiniAudioArt" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="UniformToFill" Opacity="0.3" Visibility="Collapsed" />
                
                <!-- Dimming overlay to make controls stand out -->
                <Grid x:Name="MiniControlsDimmer" Background="#80000000" Visibility="Collapsed" IsHitTestVisible="False" />

                <!-- Center Control Buttons -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    
                    <!-- Previous Button -->
                    <Button
                        Click="OnMiniPreviousClick"
                        Style="{StaticResource MiniIconButtonStyle}"
                        ToolTipService.ToolTip="Previous">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Glyph="&#xE892;" Foreground="White" />
                    </Button>

                    <!-- Play/Pause Button -->
                    <Button
                        Style="{StaticResource MiniPlayPauseButtonStyle}"
                        Click="OnMiniPlayPauseClick"
                        ToolTipService.ToolTip="Play">
                        <FontIcon
                            x:Name="MiniPlayPauseIcon"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="20"
                            Glyph="&#xE768;"
                            Foreground="White"
                            Margin="2,0,0,0" />
                    </Button>

                    <!-- Next Button -->
                    <Button
                        Click="OnMiniNextClick"
                        Style="{StaticResource MiniIconButtonStyle}"
                        ToolTipService.ToolTip="Next">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="20" Glyph="&#xE893;" Foreground="White" />
                    </Button>
                </StackPanel>

                <!-- Revert / Exit PiP Button in Bottom Right -->
                <Button
                    Click="OnMiniExitPipClick"
                    Style="{StaticResource MiniIconButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,16,16"
                    ToolTipService.ToolTip="Exit Picture in Picture">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" Glyph="&#xE93A;" Foreground="White" />
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
