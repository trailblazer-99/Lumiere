<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LumiereMediaPlayer.Controls.QueuePanel"
    x:Name="PanelRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LumiereMediaPlayer.Controls"
    xmlns:models="using:LumiereMediaPlayer.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DataType="local:QueuePanel"
    mc:Ignorable="d"
    Width="360">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <TextBlock
                Style="{StaticResource SectionHeaderTextStyle}"
                Margin="0"
                Text="Up next" />
        </Grid>

        <!-- Empty state -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            Padding="0,40"
            Spacing="8"
            VerticalAlignment="Top"
            Visibility="{x:Bind ViewModel.EmptyMessageVisibility, Mode=OneWay}">
            <FontIcon
                FontSize="32"
                Glyph="&#xE8FD;"
                HorizontalAlignment="Center"
                Opacity="0.4" />
            <TextBlock
                HorizontalAlignment="Center"
                Style="{StaticResource SubtleCaptionTextStyle}"
                Text="Your queue is empty." />
        </StackPanel>

        <!-- Queue list -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
            MaxHeight="420"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:QueueEntry">
                    <Grid Padding="4,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Accent indicator bar for current track feel -->
                        <Border
                            Grid.Column="0"
                            CornerRadius="2"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            Opacity="0.6"
                            Width="3"
                            VerticalAlignment="Stretch"
                            Margin="0,2" />

                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ElementName=PanelRoot, Path=ViewModel.PlayEntryCommand}"
                            CommandParameter="{x:Bind}"
                            Padding="0">
                            <StackPanel Spacing="2">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    MaxLines="1"
                                    Text="{x:Bind Title}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Style="{StaticResource SubtleCaptionTextStyle}"
                                    MaxLines="1"
                                    Text="{x:Bind Artist}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Button>

                        <TextBlock
                            Grid.Column="2"
                            Style="{StaticResource SubtleCaptionTextStyle}"
                            Text="{x:Bind DurationText}"
                            VerticalAlignment="Center" />

                        <Button
                            Grid.Column="3"
                            AutomationProperties.Name="Remove from queue"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ElementName=PanelRoot, Path=ViewModel.RemoveEntryCommand}"
                            CommandParameter="{x:Bind}"
                            CornerRadius="16"
                            Height="32"
                            Padding="8,0"
                            Width="32"
                            ToolTipService.ToolTip="Remove">
                            <FontIcon FontSize="12" Glyph="&#xE711;" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
