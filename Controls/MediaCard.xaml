<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LumiereMediaPlayer.Controls.MediaCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="{x:Bind CardWidth, Mode=OneWay}"
    PointerEntered="OnPointerEntered"
    PointerExited="OnPointerExited">

    <StackPanel Spacing="10">
        <!-- Album art container with hover overlay -->
        <Grid>
            <Canvas x:Name="ShadowHost" />
            <Border
                x:Name="AlbumArtBackground"
                Height="{x:Bind CardHeight, Mode=OneWay}"
                CornerRadius="{StaticResource AlbumArtCornerRadiusFull}">
                <Grid>
                    <FontIcon
                        FontSize="48"
                        Foreground="White"
                        Glyph="&#xE8D6;"
                        HorizontalAlignment="Center"
                        Opacity="0.85"
                        VerticalAlignment="Center" />
                    <Image Source="{x:Bind Artwork, Mode=OneWay}" Stretch="UniformToFill" />
                    <Image x:Name="PosterImageElement" Stretch="UniformToFill" />
                </Grid>
            </Border>

            <!-- Hover play overlay -->
            <Border
                x:Name="PlayOverlay"
                Height="{x:Bind CardHeight, Mode=OneWay}"
                CornerRadius="{StaticResource AlbumArtCornerRadiusFull}"
                Opacity="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0.0"/>
                        <GradientStop Color="#90000000" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Frosted circle behind play icon -->
                    <Border Width="48" Height="48" CornerRadius="24" Background="#33FFFFFF" BorderBrush="#66FFFFFF" BorderThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <FontIcon
                            FontSize="20"
                            Foreground="White"
                            Glyph="&#xE768;"
                            Margin="3,0,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Spacing="2">
            <TextBlock
                FontWeight="SemiBold"
                FontSize="13"
                MaxLines="1"
                Text="{x:Bind Title, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Style="{StaticResource SubtleCaptionTextStyle}"
                MaxLines="1"
                Text="{x:Bind Subtitle, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </StackPanel>
</UserControl>
