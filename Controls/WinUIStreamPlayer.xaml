<UserControl
    x:Class="FluentMediaPlayer.Controls.WinUIStreamPlayer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="400"
    d:DesignWidth="600"
    Unloaded="OnUnloaded">

    <Grid Background="Black" PointerMoved="OnPointerMoved">
        <!-- Native MediaPlayer -->
        <MediaPlayerElement x:Name="Player" 
                            AreTransportControlsEnabled="False" 
                            HorizontalAlignment="Stretch" 
                            VerticalAlignment="Stretch"/>
        <Rectangle Fill="Transparent" IsHitTestVisible="True" DoubleTapped="OnVideoDoubleTapped" />

        <!-- Custom Control Bar Overlay -->
        <Grid x:Name="OverlayGrid" VerticalAlignment="Bottom" Margin="16" CornerRadius="12">
            
            <!-- Glassy Acrylic/Mica effect background -->
            <Grid.Background>
                <AcrylicBrush TintOpacity="0.6" TintColor="Black" FallbackColor="#DD000000" />
            </Grid.Background>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Loading Spinner (Centered over the whole player) -->
            <ProgressRing x:Name="LoadingRing" 
                          IsActive="False"
                          Width="64" Height="64" 
                          Foreground="White"
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"
                          Margin="0,0,0,100"
                          Grid.RowSpan="2" />

            <!-- Timeline -->
            <Slider x:Name="TimelineSlider" 
                    Grid.Row="0"
                    Margin="16,8,16,0"
                    Minimum="0" Maximum="1" 
                    StepFrequency="1"
                    ValueChanged="TimelineSlider_ValueChanged" />

            <!-- Bottom Controls -->
            <Grid Grid.Row="1" Padding="16,4,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <!-- Play/Pause Button (User will provide logo later) -->
                    <Button x:Name="PlayPauseButton" 
                            Click="OnPlayPauseClick" 
                            Background="Transparent" 
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="8">
                        <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" Foreground="White" FontSize="18"/>
                    </Button>

                    <!-- Volume -->
                    <Button Background="Transparent" BorderThickness="0" Padding="8">
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Width="150" Padding="8">
                                    <Slider Minimum="0" Maximum="100" Value="100" ValueChanged="OnVolumeChanged" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                        <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" Foreground="White" FontSize="18"/>
                    </Button>
                    
                    <!-- Time display -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock x:Name="TimeTextBlock" Text="00:00 / 00:00" Foreground="White" Opacity="0.8" FontSize="14"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <!-- Fullscreen Toggle -->
                    <Button Click="OnFullscreenClick" Background="Transparent" BorderThickness="0" Padding="8">
                        <FontIcon Glyph="&#xE740;" Foreground="White" FontSize="18"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

